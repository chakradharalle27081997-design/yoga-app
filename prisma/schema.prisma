generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Client {
  id         String     @id @default(cuid())
  name       String
  age        Int
  gender     String?
  experience String
  injuries   String     @default("")
  conditions String     @default("")
  notes      String?
  joinDate   DateTime   @default(now())
  goals      String     @default("")
  surgeries  String     @default("")
  familyHistory String  @default("")
  stressLevel   String  @default("")
  sleepPattern  String  @default("")
  angerLevel    String  @default("")
  mealType      String  @default("")
  stayType      String  @default("")
  phone         String  @default("")
  pin           String  @default("")
  sequences  Sequence[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}
model Sequence {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  duration    Int
  style       String
  goal        String
  energy      String
  cycleNumber Int      @default(1)
  poses       String   @db.Text
  createdAt   DateTime @default(now())
}
